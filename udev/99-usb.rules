ACTION=="add", SUBSYSTEM=="block", ENV{ID_BUS}=="usb", RUN+="/bin/sh -c 'echo $(date +%%Y-%%m-%%d_%%H:%%M:%%S) ADDED device=%k vendor=$env{ID_VENDOR} model=$env{ID_MODEL} >> /tmp/usb-test.log'"
ACTION=="remove", SUBSYSTEM=="block", ENV{ID_BUS}=="usb", RUN+="/bin/sh -c 'echo $(date +%%Y-%%m-%%d_%%H:%%M:%%S) REMOVED device=%k vendor=$env{ID_VENDOR} model=$env{ID_MODEL} >> /tmp/usb-test.log'"
